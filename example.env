# Jobotron Environment Variables Example
# Duplicate this file to .env and fill in your actual credentials.

# MongoDB Configuration
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@your-cluster.mongodb.net/?retryWrites=true&w=majority&appName=Jobotron

# X (Twitter) API Configuration
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret
X_BEARER_TOKEN=your_bearer_token
X_API_KEY=your_api_key
X_API_SECRET=your_api_key_secret
X_CLIENT_ID=your_client_id
X_CLIENT_SECRET=your_client_secret

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key
